{
    "name": "trading-platform-frontend",
    "private": true,
    "version": "2.6.0",
    "type": "module",
    "scripts": {
        "preinstall": "node -e \"const pkg=require('./package.json'); if(pkg.dependencies.axios !== '1.13.6'){ console.error('\\n\\x1b[41m\\x1b[37m SECURITY ALERT: AXIOS UPDATE BLOCKED \\x1b[0m\\nVersions 1.14.1 and 0.30.4 contain known malware (March 2026 Supply Chain Attack).\\nExpected: 1.13.6\\nFound: ' + pkg.dependencies.axios + '\\n\\nPlease revert axios in package.json to 1.13.6.\\n'); process.exit(1); }\"",
        "dev": "vite --port 3000",
        "build": "vite build",
        "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
        "preview": "vite preview"
    },
    "dependencies": {
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "framer-motion": "^10.12.16",
        "lucide-react": "^0.221.0",
        "plotly.js": "^2.22.0",
        "react-plotly.js": "^2.6.0",
        "tailwindcss": "^3.3.2",
        "autoprefixer": "^10.4.14",
        "postcss": "^8.4.24",
        "axios": "1.13.6",
        "clsx": "^1.2.1",
        "tailwind-merge": "^1.12.0"
    },
    "devDependencies": {
        "@types/react": "^18.0.37",
        "@types/react-dom": "^18.0.11",
        "@vitejs/plugin-react": "^4.0.0",
        "eslint": "^8.38.0",
        "eslint-plugin-react": "^7.32.2",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.3.4",
        "vite": "^4.3.9"
    },
    "overrides": {
        "axios": "1.13.6"
    }
}